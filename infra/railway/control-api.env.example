# Control API baseline env
NODE_ENV=production
PORT=3000
APP_VERSION=0.1.0

# Keep true once migrations are applied in the target environment.
REQUIRE_DB=true

# Railway variable reference target:
# DATABASE_URL=${{Postgres.DATABASE_URL}}
DATABASE_URL=

# Rotate with high entropy random values in each environment.
JWT_ACCESS_SECRET=
JWT_ISSUER=datascrap-control-api
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30
DEFAULT_MAX_DEVICES=2
