NODE_ENV=development
PORT=3000
APP_VERSION=0.1.0

# Set to true to require a successful DB check in /readyz.
REQUIRE_DB=false

# Railway should populate this using the Postgres service reference.
DATABASE_URL=

# Rotate these in staging/production.
JWT_ACCESS_SECRET=change-me
# Optional keyring format for no-downtime key rotation:
# JWT_ACCESS_SECRETS=k20260223:secretA,k20260401:secretB
# JWT_ACTIVE_KID=k20260401
JWT_ACCESS_SECRETS=
JWT_ACTIVE_KID=
JWT_ISSUER=datascrap-control-api
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30
DEFAULT_MAX_DEVICES=2

# CORS policy
CORS_STRICT=false
CORS_ALLOW_NO_ORIGIN=true
CORS_ALLOWED_ORIGINS=
CORS_ALLOWED_ORIGIN_PREFIXES=chrome-extension://

# Rate limits
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_AUTH_REGISTER_MAX=10
RATE_LIMIT_AUTH_LOGIN_MAX=15
RATE_LIMIT_AUTH_REFRESH_MAX=30
RATE_LIMIT_AUTH_LOGOUT_MAX=60
RATE_LIMIT_LICENSE_REGISTER_MAX=30
RATE_LIMIT_LICENSE_STATUS_MAX=60
RATE_LIMIT_DEVICES_VALIDATE_MAX=120
RATE_LIMIT_DEVICES_MUTATE_MAX=60
RATE_LIMIT_DEVICES_LIST_MAX=120

# Idempotency replay cache TTL (DB-backed)
IDEMPOTENCY_TTL_HOURS=24

# Observability
ENABLE_METRICS_ENDPOINT=true
METRICS_WINDOW_MINUTES=60
METRICS_MAX_SAMPLES=20000
OBSERVABILITY_API_KEY=

# Optional error tracking webhook
ERROR_TRACKING_WEBHOOK_URL=
ERROR_TRACKING_WEBHOOK_BEARER_TOKEN=
ERROR_TRACKING_MIN_INTERVAL_SECONDS=15

# Read cache (hot read path optimization)
ENABLE_READ_CACHE=true
READ_CACHE_DEFAULT_TTL_SECONDS=20
READ_CACHE_MAX_ENTRIES=5000
LICENSE_STATUS_CACHE_TTL_SECONDS=20
DEVICES_LIST_CACHE_TTL_SECONDS=15

# Optional cloud features (Phase 5)
ENABLE_OPTIONAL_CLOUD_FEATURES=false
OPT_IN_POLICY_VERSION=2026-02-23
MAX_METADATA_PAYLOAD_BYTES=32768

# Background job worker
JOB_POLL_INTERVAL_MS=2000
JOB_MAX_ATTEMPTS_DEFAULT=5
JOB_BACKOFF_BASE_SECONDS=15
JOB_BACKOFF_MULTIPLIER=2
JOB_BACKOFF_MAX_SECONDS=900
JOB_LOCK_TIMEOUT_SECONDS=300
JOB_LIST_MAX_LIMIT=100
JOB_WORKER_ID=
CONTROL_API_RUNTIME_MODE=api
SCHEDULE_SWEEP_INTERVAL_MS=5000
SCHEDULE_SWEEP_MAX_BATCH=10
SCHEDULE_LIST_MAX_LIMIT=100
CRON_MAX_LOOKAHEAD_MINUTES=525600

# Integration secret vault (required in production if optional cloud features are enabled)
# Use base64(32 bytes) or 64-char hex. Example generation:
# openssl rand -base64 32
VAULT_MASTER_KEY=
VAULT_REQUIRE_KEY=false
