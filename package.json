{
  "name": "datascrap",
  "version": "0.1.0",
  "private": true,
  "description": "Datascrap control plane bootstrap",
  "scripts": {
    "start": "node services/control-api/scripts/start-runtime.js",
    "start:control-api": "node services/control-api/src/server.js",
    "dev:control-api": "node --watch services/control-api/src/server.js",
    "sync:extension": "node scripts/sync-extension-packages.mjs",
    "package:extension": "node scripts/package-extension.mjs",
    "release:extension": "npm run sync:extension && npm run smoke:extension && npm run package:extension",
    "release:full": "npm run hardening:railway && npm run release:extension",
    "smoke:extension:storage": "node scripts/smoke-extension-storage.mjs",
    "smoke:extension:table-advanced": "node scripts/smoke-extension-table-advanced.mjs",
    "smoke:extension:runtime": "node scripts/smoke-extension-runtime.mjs",
    "smoke:extension:epic5": "node scripts/smoke-extension-epic5.mjs",
    "smoke:extension:epic6": "node scripts/smoke-extension-epic6.mjs",
    "smoke:extension:epic7": "node scripts/smoke-extension-epic7.mjs",
    "smoke:extension:epic8": "node scripts/smoke-extension-epic8.mjs",
    "smoke:extension:epic9": "node scripts/smoke-extension-epic9.mjs",
    "smoke:extension:epic10": "node scripts/smoke-extension-epic10.mjs",
    "smoke:extension:epic11": "node scripts/smoke-extension-epic11.mjs",
    "smoke:extension:epic12": "node scripts/smoke-extension-epic12.mjs",
    "smoke:extension:epic13": "node scripts/smoke-extension-epic13.mjs",
    "smoke:extension:epic14": "node scripts/smoke-extension-epic14.mjs",
    "smoke:extension": "npm run smoke:extension:storage && npm run smoke:extension:table-advanced && npm run smoke:extension:runtime && npm run smoke:extension:epic5 && npm run smoke:extension:epic6 && npm run smoke:extension:epic7 && npm run smoke:extension:epic8 && npm run smoke:extension:epic9 && npm run smoke:extension:epic10 && npm run smoke:extension:epic11 && npm run smoke:extension:epic12 && npm run smoke:extension:epic13 && npm run smoke:extension:epic14",
    "test:local:hardening": "node scripts/local-hardening-pass.mjs",
    "hardening:railway": "node scripts/hardening-railway.mjs",
    "smoke:control-api": "node services/control-api/scripts/smoke.js",
    "migrate:control-api": "node services/control-api/scripts/migrate.js",
    "uptime:control-api": "node services/control-api/scripts/uptime-monitor.js",
    "slo:control-api": "node services/control-api/scripts/slo-monitor.js",
    "cost:control-api": "node services/control-api/scripts/cost-monitor.js",
    "backup:verify:control-api": "node services/control-api/scripts/backup-verify.js",
    "chaos:check:control-api": "node services/control-api/scripts/chaos-check.js",
    "jwt:generate:control-api": "node services/control-api/scripts/generate-jwt-secret.js",
    "jobs:worker:control-api": "node services/control-api/scripts/jobs-worker.js",
    "phase5:smoke:control-api": "node services/control-api/scripts/phase5-smoke.js",
    "phase5:schedule:smoke:control-api": "node services/control-api/scripts/phase5-schedule-smoke.js",
    "phase9:monitor:smoke:control-api": "node services/control-api/scripts/phase9-monitor-smoke.js",
    "queue:monitor:control-api": "node services/control-api/scripts/job-queue-monitor.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.13.1"
  }
}
